@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="page-header">
    <div class="container">
        <h1 class="fw-bold text-white"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</h1>
        <p class="text-white-50">Theo dõi tiến độ học tập của bạn</p>
    </div>
</section>

<div class="container py-4">
    <!-- Stats Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-primary-subtle text-primary"><i class="fas fa-fire"></i></div>
                <h3 class="fw-bold mb-1">@Model.Streak <span class="fs-6 text-muted fw-normal">ngày</span></h3>
                <p class="text-muted mb-0 small">Chuỗi học tập</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-success-subtle text-success"><i class="fas fa-check-circle"></i></div>
                <h3 class="fw-bold mb-1">@Model.LearnedCards / @Model.TotalCards</h3>
                <p class="text-muted mb-0 small">Từ đã thuộc</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-info-subtle text-info"><i class="fas fa-layer-group"></i></div>
                <h3 class="fw-bold mb-1">@Model.TotalSets</h3>
                <p class="text-muted mb-0 small">Bộ từ vựng</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning-subtle text-warning"><i class="fas fa-star"></i></div>
                <h3 class="fw-bold mb-1">@Model.AverageScore%</h3>
                <p class="text-muted mb-0 small">Điểm test trung bình</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Sets -->
        <div class="col-lg-8">
            <div class="glass-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0"><i class="fas fa-clock me-2"></i>Bộ từ học gần đây</h5>
                    <a href="/VocabularySet/MySets" class="btn btn-sm btn-outline-primary rounded-pill">Xem tất cả</a>
                </div>
                
                @if (Model.RecentSets.Any())
                {
                    <div class="row g-3">
                        @foreach (var set in Model.RecentSets)
                        {
                            <div class="col-md-6">
                                <div class="set-card h-100">
                                    <div class="set-card-header">
                                        <span class="badge bg-primary-subtle text-primary">@(set.Category?.CategoryName ?? "Chưa phân loại")</span>
                                        <span class="badge bg-light text-dark"><i class="fas fa-clone me-1"></i>@set.Cards.Count từ</span>
                                    </div>
                                    <h6 class="fw-bold mt-2 text-truncate">@set.Title</h6>
                                    
                                    @{
                                        // Find progress for this set safely
                                        var progress = set.Progresses?.FirstOrDefault(p => p.UserId == int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0"));
                                        double percent = progress?.MasteryPercent ?? 0;
                                    }
                                    <div class="mt-3">
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span class="text-muted">Độ thành thạo</span>
                                            <span class="fw-semibold">@percent%</span>
                                        </div>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-gradient-primary" style="width: @percent%"></div>
                                        </div>
                                    </div>
                                    
                                    <div class="mt-3 text-end">
                                        <a href="/Study/Flashcard/@set.SetId" class="btn btn-sm btn-primary-gradient rounded-pill px-3">
                                            Học tiếp <i class="fas fa-arrow-right ms-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <p class="text-muted">Chưa có bộ từ nào.</p>
                        <a href="/VocabularySet/Create" class="btn btn-primary-gradient rounded-pill px-4">Tạo bộ từ đầu tiên</a>
                    </div>
                }
            </div>
        </div>
        
        <!-- Recent Tests & Activity -->
        <div class="col-lg-4">
            <div class="glass-card mb-4">
                <h5 class="fw-bold mb-3"><i class="fas fa-clipboard-check me-2"></i>Bài test gần đây</h5>
                @if (Model.RecentTests.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var test in Model.RecentTests)
                        {
                            <li class="list-group-item bg-transparent px-0 border-light border-opacity-25 d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0 text-truncate" style="max-width: 150px;">@test.VocabularySet?.Title</h6>
                                    <small class="text-muted">@test.CreatedAt.ToString("dd/MM")</small>
                                </div>
                                <span class="badge @(test.Score >= 80 ? "bg-success" : test.Score >= 50 ? "bg-primary" : "bg-danger") rounded-pill px-3">
                                    @test.Score%
                                </span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted small text-center my-3">Chưa có bài test nào.</p>
                }
                <div class="text-center mt-3">
                    <a href="/Test/History" class="text-decoration-none small">Xem lịch sử test <i class="fas fa-angle-right ms-1"></i></a>
                </div>
            </div>
            
            <div class="glass-card">
                <h5 class="fw-bold mb-3"><i class="fas fa-chart-pie me-2"></i>Tổng quan</h5>
                <div class="d-flex justify-content-center">
                    <div style="width: 180px; height: 180px;">
                        <canvas id="masteryChart"></canvas>
                    </div>
                </div>
                <div class="text-center mt-3">
                    <p class="mb-0 fw-semibold text-primary">@Model.OverallMastery%</p>
                    <small class="text-muted">Độ thành thạo trung bình</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const ctx = document.getElementById('masteryChart').getContext('2d');
        const mastery = @Model.OverallMastery;
        const remainder = 100 - mastery;
        
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['Thành thạo', 'Chưa thành thạo'],
                datasets: [{
                    data: [mastery, remainder],
                    backgroundColor: [
                        '#667eea',
                        'rgba(255, 255, 255, 0.1)'
                    ],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: {
                    legend: { display: false },
                    tooltip: { enabled: true }
                }
            }
        });
    });
</script>
}
