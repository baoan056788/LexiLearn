@model List<LexiLearn.Models.VocabularySet>
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <h1 class="display-4 fw-bold text-white mb-3">
                    Học từ vựng <span class="text-gradient">tiếng Anh</span> thông minh
                </h1>
                <p class="lead text-white-50 mb-4">
                    Flashcard, Quiz, Match Game — học mọi lúc, nhớ lâu hơn với Goan
                </p>
                <div class="d-flex gap-3">
                    <a href="/Auth/Register" class="btn btn-light btn-lg px-4 rounded-pill fw-semibold">
                        <i class="fas fa-rocket me-2"></i>Bắt đầu
                    </a>
                    <a href="/Home/Explore" class="btn btn-outline-light btn-lg px-4 rounded-pill">
                        <i class="fas fa-compass me-2"></i>Khám phá
                    </a>
                </div>
            </div>
            <div class="col-lg-6 text-center mt-5 mt-lg-0">
                <div class="hero-illustration">
                    <div class="floating-card card-1">
                        <div class="card-inner">
                            <div class="card-front"><span class="term">Achieve</span></div>
                        </div>
                    </div>
                    <div class="floating-card card-2">
                        <div class="card-inner">
                            <div class="card-front"><span class="term">Success</span></div>
                        </div>
                    </div>
                    <div class="floating-card card-3">
                        <div class="card-inner">
                            <div class="card-front"><span class="term">Learn</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="py-5">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="stat-card text-center">
                    <div class="stat-icon"><i class="fas fa-users"></i></div>
                    <h3 class="fw-bold">@ViewBag.TotalUsers</h3>
                    <p class="text-muted mb-0">Người dùng</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card text-center">
                    <div class="stat-icon"><i class="fas fa-layer-group"></i></div>
                    <h3 class="fw-bold">@ViewBag.TotalSets</h3>
                    <p class="text-muted mb-0">Bộ từ vựng</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card text-center">
                    <div class="stat-icon"><i class="fas fa-clone"></i></div>
                    <h3 class="fw-bold">@ViewBag.TotalCards</h3>
                    <p class="text-muted mb-0">Thẻ từ</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5 bg-light-custom">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">Tính năng <span class="text-gradient">nổi bật</span></h2>
        <div class="row g-4">
            <div class="col-md-3">
                <a href="/VocabularySet/MySets?mode=flashcard" class="text-decoration-none text-dark">
                    <div class="feature-card text-center bg-white shadow-sm rounded p-4 h-100" style="transition: transform 0.2s;">
                        <div class="feature-icon mb-3 fs-2 text-primary"><i class="fas fa-clone"></i></div>
                        <h5 class="fw-bold text-dark">Flashcard</h5>
                        <p class="text-muted small mb-0">Lật thẻ học từ, ghi nhớ nhanh chóng</p>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a href="/VocabularySet/MySets?mode=test" class="text-decoration-none text-dark">
                    <div class="feature-card text-center bg-white shadow-sm rounded p-4 h-100" style="transition: transform 0.2s;">
                        <div class="feature-icon mb-3 fs-2 text-primary"><i class="fas fa-pen-to-square"></i></div>
                        <h5 class="fw-bold text-dark">Test</h5>
                        <p class="text-muted small mb-0">Kiểm tra kiến thức với trắc nghiệm</p>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a href="/VocabularySet/MySets?mode=match" class="text-decoration-none text-dark">
                    <div class="feature-card text-center bg-white shadow-sm rounded p-4 h-100" style="transition: transform 0.2s;">
                        <div class="feature-icon mb-3 fs-2 text-primary"><i class="fas fa-puzzle-piece"></i></div>
                        <h5 class="fw-bold text-dark">Match Game</h5>
                        <p class="text-muted small mb-0">Nối từ tiếng Anh với nghĩa tiếng Việt</p>
                    </div>
                </a>
            </div>
            <div class="col-md-3">
                <a href="/Progress/Dashboard" class="text-decoration-none text-dark">
                    <div class="feature-card text-center bg-white shadow-sm rounded p-4 h-100" style="transition: transform 0.2s;">
                        <div class="feature-icon mb-3 fs-2 text-primary"><i class="fas fa-chart-line"></i></div>
                        <h5 class="fw-bold text-dark">Tiến độ</h5>
                        <p class="text-muted small mb-0">Theo dõi quá trình học tập</p>
                    </div>
                </a>
            </div>
        </div>
        <style>
            .feature-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important; }
        </style>
    </div>
</section>

<!-- Public Sets Section -->
@if (Model.Any())
{
    <section class="py-5">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold">Bộ từ <span class="text-gradient">công khai</span></h2>
                <a href="/Home/Explore" class="btn btn-outline-primary rounded-pill">Xem tất cả <i class="fas fa-arrow-right ms-1"></i></a>
            </div>
            <div class="row g-4">
                @foreach (var set in Model)
                {
                    <div class="col-md-4">
                        <div class="set-card">
                            <div class="set-card-header">
                                <span class="badge bg-primary-subtle text-primary">@(set.Category?.CategoryName ?? "Chưa phân loại")</span>
                                <span class="badge bg-light text-dark"><i class="fas fa-clone me-1"></i>@set.Cards.Count từ</span>
                            </div>
                            <h5 class="fw-bold mt-2">@set.Title</h5>
                            <p class="text-muted small mb-3">@(set.Description ?? "Không có mô tả")</p>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted"><i class="fas fa-user me-1"></i>@set.User?.FullName</small>
                                <a href="/VocabularySet/Details/@set.SetId" class="btn btn-sm btn-primary-gradient rounded-pill px-3">
                                    Xem <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}
