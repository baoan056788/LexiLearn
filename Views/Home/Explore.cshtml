@model ExploreViewModel
@{
    ViewData["Title"] = "Khám phá bộ từ";
}

<section class="page-header">
    <div class="container">
        <h1 class="fw-bold text-white"><i class="fas fa-compass me-2"></i>Khám phá bộ từ vựng</h1>
        <p class="text-white-50">Tìm kiếm và học từ bộ từ công khai của cộng đồng</p>
    </div>
</section>

<div class="container py-4">
    <!-- Search & Filter -->
    <div class="glass-card mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-semibold"><i class="fas fa-search me-1"></i>Tìm kiếm</label>
                <input type="text" name="search" class="form-control" placeholder="Nhập từ khóa..." value="@Model.SearchQuery" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold"><i class="fas fa-folder me-1"></i>Danh mục</label>
                <select name="categoryId" class="form-select">
                    <option value="">Tất cả danh mục</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat.CategoryId" selected="@(Model.CategoryId == cat.CategoryId)">@cat.CategoryName</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary-gradient w-100"><i class="fas fa-search me-2"></i>Tìm kiếm</button>
            </div>
        </form>
    </div>

    <!-- Results -->
    @if (Model.Sets.Any())
    {
        <div class="row g-4">
            @foreach (var set in Model.Sets)
            {
                <div class="col-md-4">
                    <div class="set-card">
                        <div class="set-card-header">
                            <span class="badge bg-primary-subtle text-primary">@(set.Category?.CategoryName ?? "Chưa phân loại")</span>
                            <span class="badge bg-light text-dark"><i class="fas fa-clone me-1"></i>@set.Cards.Count từ</span>
                        </div>
                        <h5 class="fw-bold mt-2">@set.Title</h5>
                        <p class="text-muted small mb-3">@(set.Description ?? "Không có mô tả")</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted"><i class="fas fa-user me-1"></i>@set.User?.FullName</small>
                            <a href="/VocabularySet/Details/@set.SetId" class="btn btn-sm btn-primary-gradient rounded-pill px-3">
                                Xem <i class="fas fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="?search=@Model.SearchQuery&categoryId=@Model.CategoryId&page=@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-search fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">Không tìm thấy bộ từ nào</h4>
            <p class="text-muted">Thử thay đổi từ khóa hoặc danh mục</p>
        </div>
    }
</div>
