@model List<VocabularySet>
@{
    ViewData["Title"] = "Bộ từ của tôi";
}

<section class="page-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                @if (!string.IsNullOrEmpty(ViewBag.Mode as string))
                {
                    <h1 class="fw-bold text-white"><i class="fas fa-mouse-pointer me-2"></i>Chọn bộ từ để học</h1>
                    <p class="text-white-50 mb-0">Chọn một bộ từ vựng để bắt đầu</p>
                }
                else
                {
                    <h1 class="fw-bold text-white"><i class="fas fa-layer-group me-2"></i>Bộ từ của tôi</h1>
                    <p class="text-white-50 mb-0">Quản lý các bộ từ vựng của bạn</p>
                }
            </div>
            <a href="/VocabularySet/Create" class="btn btn-light rounded-pill px-4">
                <i class="fas fa-plus me-2"></i>Tạo bộ từ mới
            </a>
        </div>
    </div>
</section>

<div class="container py-4">
    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var set in Model)
            {
                <div class="col-md-4">
                    <div class="set-card h-100 d-flex flex-column">
                        <div class="set-card-header">
                            <span class="badge bg-primary-subtle text-primary">@(set.Category?.CategoryName ?? "Chưa phân loại")</span>
                            <div>
                                <span class="badge bg-light text-dark"><i class="fas fa-clone me-1"></i>@set.Cards.Count từ</span>
                                @if (set.IsPublic)
                                {
                                    <span class="badge bg-success-subtle text-success"><i class="fas fa-globe me-1"></i>Công khai</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary"><i class="fas fa-lock me-1"></i>Riêng tư</span>
                                }
                            </div>
                        </div>
                        <h5 class="fw-bold mt-2">@set.Title</h5>
                        <p class="text-muted small mb-3 flex-grow-1">@(set.Description ?? "Không có mô tả")</p>
                        <div class="d-flex gap-2 flex-wrap mt-auto">
                            @if (!string.IsNullOrEmpty(ViewBag.Mode as string))
                            {
                                var mode = ViewBag.Mode as string;
                                var actionUrl = mode switch {
                                    "flashcard" => $"/Study/Flashcard/{set.SetId}",
                                    "test" => $"/Test/Setup/{set.SetId}",
                                    "match" => $"/Study/MatchGame/{set.SetId}",
                                    "learn" => $"/Learn/Index/{set.SetId}",
                                    _ => $"/VocabularySet/Details/{set.SetId}"
                                };
                                <a href="@actionUrl" class="btn btn-primary-gradient rounded-pill px-4 w-100">
                                    <i class="fas fa-play me-2"></i>Bắt đầu học
                                </a>
                            }
                            else
                            {
                                <a href="/VocabularySet/Details/@set.SetId" class="btn btn-sm btn-primary-gradient rounded-pill px-3">
                                    <i class="fas fa-eye me-1"></i>Chi tiết
                                </a>
                                <a href="/Study/Flashcard/@set.SetId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                    <i class="fas fa-clone me-1"></i>Flashcard
                                </a>
                                <a href="/VocabularySet/Edit/@set.SetId" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                    <i class="fas fa-edit me-1"></i>Sửa
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-folder-open fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">Bạn chưa có bộ từ nào</h4>
            <p class="text-muted">Hãy tạo bộ từ đầu tiên để bắt đầu học!</p>
            <a href="/VocabularySet/Create" class="btn btn-primary-gradient rounded-pill px-4 mt-2">
                <i class="fas fa-plus me-2"></i>Tạo bộ từ mới
            </a>
        </div>
    }
</div>
