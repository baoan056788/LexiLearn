@model VocabularySetViewModel
@{
    ViewData["Title"] = "Tạo bộ từ mới";
}

<section class="page-header">
    <div class="container">
        <h1 class="fw-bold text-white"><i class="fas fa-plus-circle me-2"></i>Tạo bộ từ mới</h1>
    </div>
</section>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-card">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold"></label>
                        <input asp-for="Title" class="form-control" placeholder="Ví dụ: TOEIC 600 từ vựng cốt lõi..." />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Mô tả ngắn gọn về bộ từ..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="CategoryId" class="form-label fw-bold"></label>
                        <select asp-for="CategoryId" class="form-select">
                            <option value="">-- Không phân loại --</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat.CategoryId">@cat.CategoryName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ImportFile" class="form-label fw-bold">Nhập từ file Excel (Tùy chọn)</label>
                        <input asp-for="ImportFile" type="file" class="form-control" accept=".xlsx, .xls" />
                        <div class="form-text">
                            Hỗ trợ file Excel (.xlsx, .xls). Cấu trúc cột mặc định: <b>Từ vựng, Nghĩa, Phiên âm, Ví dụ</b>. Hàng đầu tiên sẽ được coi là tiêu đề và bị bỏ qua.
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsPublic" class="form-check-input" />
                            <label asp-for="IsPublic" class="form-check-label">Chia sẻ công khai cho cộng đồng</label>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary-gradient px-4">
                            <i class="fas fa-save me-2"></i>Tạo bộ từ
                        </button>
                        <a href="/VocabularySet/MySets" class="btn btn-outline-secondary px-4">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
