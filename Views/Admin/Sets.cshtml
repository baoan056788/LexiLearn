@model List<LexiLearn.Models.VocabularySet>
@{
    ViewData["Title"] = "Quản lý Bộ từ Công khai";
    Layout = "_AdminLayout";
}

<div class="admin-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" class="form-control" placeholder="Tìm kiếm bộ từ..." value="@ViewBag.Search" />
            <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Tên bộ từ</th>
                    <th>Người tạo</th>
                    <th>Danh mục</th>
                    <th>Số thẻ từ</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var set in Model)
                {
                    <tr>
                        <td class="fw-semibold">
                            <a href="/VocabularySet/Details/@set.SetId" target="_blank" class="text-decoration-none">
                                @set.Title <i class="fas fa-external-link-alt small ms-1"></i>
                            </a>
                        </td>
                        <td>@set.User?.FullName</td>
                        <td><span class="badge bg-light text-dark">@(set.Category?.CategoryName ?? "None")</span></td>
                        <td>@set.Cards.Count</td>
                        <td>
                            @if (set.IsPublic)
                            {
                                <span class="badge bg-success">Công khai</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Đã ẩn</span>
                            }
                        </td>
                        <td class="text-end">
                            <form asp-action="ToggleSetVisibility" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@set.SetId" />
                                @if (set.IsPublic)
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-warning" onclick="return confirm('Bạn muốn ẩn bộ từ này khỏi cộng đồng?')">Ẩn</button>
                                }
                                else
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-success" onclick="return confirm('Bạn muốn cho phép công khai bộ từ này lại?')">Hiện</button>
                                }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
