@model List<LexiLearn.Models.User>
@{
    ViewData["Title"] = "Quản lý Người dùng";
    Layout = "_AdminLayout";
}

<div class="admin-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="search" class="form-control" placeholder="Tìm kiếm theo tên, email..." value="@ViewBag.Search" />
            <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i></button>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Ngày tham gia</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="fw-semibold">@user.FullName</td>
                        <td>@user.Email</td>
                        <td><span class="badge bg-secondary">@(user.Role?.RoleName ?? "Learner")</span></td>
                        <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Đã khóa</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (user.Email != "admin@lexilearn.com")
                            {
                                <form asp-action="ToggleUserStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.UserId" />
                                    @if (user.IsActive)
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn muốn khóa tài khoản này?')">Khóa</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="btn btn-sm btn-outline-success" onclick="return confirm('Bạn muốn mở khóa tài khoản này?')">Mở khóa</button>
                                    }
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
