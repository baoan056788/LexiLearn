@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var userName = User.Identity?.Name ?? "";
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Goan</title>
    <meta name="description" content="Goan - Website học từ vựng tiếng Anh với Flashcard, Test, Match Game" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-book-open me-2"></i>Goan
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fas fa-home me-1"></i>Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Explore"><i class="fas fa-compass me-1"></i>Khám phá</a>
                    </li>
                    @if (isAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Progress/Dashboard"><i class="fas fa-chart-line me-1"></i>Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/VocabularySet/MySets"><i class="fas fa-layer-group me-1"></i>Bộ từ của tôi</a>
                        </li>
                        @if (userRole == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Admin"><i class="fas fa-shield-alt me-1"></i>Quản trị</a>
                            </li>
                        }
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (isAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle me-1"></i>@userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/Progress/Dashboard"><i class="fas fa-tachometer-alt me-2"></i>Dashboard</a></li>
                                <li><a class="dropdown-item" href="/VocabularySet/MySets"><i class="fas fa-layer-group me-2"></i>Bộ từ của tôi</a></li>
                                <li><a class="dropdown-item" href="/Test/History"><i class="fas fa-history me-2"></i>Lịch sử test</a></li>
                                <li><hr class="dropdown-menu-divider" /></li>
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Auth/Login"><i class="fas fa-sign-in-alt me-1"></i>Đăng nhập</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-light btn-sm ms-2 px-3 rounded-pill" href="/Auth/Register">
                                <i class="fas fa-user-plus me-1"></i>Đăng ký
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @if (User.Identity?.IsAuthenticated == true)
    {
        @await Component.InvokeAsync("PinnedTabs")
    }

    <main>
        @RenderBody()
    </main>

    <footer class="footer-section">
        <div class="container text-center">
            <p class="mb-1"><i class="fas fa-book-open me-2"></i>Goan - Học từ vựng tiếng Anh</p>
            <p class="mb-0 small opacity-75">&copy; 2026 Goan. Trần Nguyễn Bảo An - MSSV: 2001230004</p>
        </div>
    </footer>

    <!-- Toast notifications -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 9999">
        @if (TempData["Success"] != null)
        {
            <div class="toast show align-items-center text-white bg-success border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body"><i class="fas fa-check-circle me-2"></i>@TempData["Success"]</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast show align-items-center text-white bg-danger border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body"><i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        }
    </div>

    <!-- Floating Dictionary Button -->
    <button class="btn btn-primary-gradient rounded-circle shadow-lg dict-fab" type="button" data-bs-toggle="offcanvas" data-bs-target="#dictOffcanvas" aria-controls="dictOffcanvas" title="Tra từ bằng AI">
        <i class="fas fa-search"></i>
    </button>

    <!-- Dictionary Offcanvas -->
    <div class="offcanvas offcanvas-end shadow" tabindex="-1" id="dictOffcanvas" aria-labelledby="dictOffcanvasLabel" data-bs-scroll="true" data-bs-backdrop="false">
        <div class="resize-handle"></div>
        <div class="offcanvas-header bg-light-custom border-bottom">
            <h5 class="offcanvas-title fw-bold" id="dictOffcanvasLabel"><i class="fas fa-wand-magic-sparkles me-2 text-primary"></i>Tra từ AI</h5>
            <div class="d-flex align-items-center">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Pin" asp-action="TogglePin" method="post" class="mb-0 me-2 d-inline-block">
                        <input type="hidden" name="itemType" value="Dictionary" />
                        <input type="hidden" name="title" value="Từ điển" />
                        <input type="hidden" name="url" value="#" /> <!-- Dictionary doesn't have a specific page, we will handle its tab click via JS or just not have a URL -->
                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                        <button type="submit" id="btnPinDict" class="btn btn-sm btn-outline-primary" title="Ghim tra từ AI vào thanh Tab Bar">
                            <i class="fas fa-thumbtack"></i>
                        </button>
                    </form>
                }
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
        </div>
        <div class="offcanvas-body">
            <form id="dictForm" class="mb-4">
                <div class="input-group shadow-sm rounded-pill overflow-hidden">
                    <input type="text" id="dictInput" class="form-control border-0 px-4" placeholder="Nhập từ tiếng Anh hoặc tiếng Việt..." required autocomplete="off">
                    <button class="btn btn-primary-gradient px-4" type="submit" id="dictSubmitBtn"><i class="fas fa-search"></i></button>
                </div>
            </form>

            <div id="dictLoading" class="text-center d-none py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="text-muted mt-2 small">Gemini đang tra từ...</p>
            </div>

            <div id="dictResult" class="d-none">
                <div class="mb-3 d-flex align-items-start justify-content-between gap-2">
                    <div>
                        <h2 class="fw-bold text-primary mb-1 text-capitalize" id="dictWord">word</h2>
                        <span class="text-muted font-monospace fs-5" id="dictIpa">/wɜːrd/</span>
                    </div>
                    <button class="btn btn-sm btn-outline-primary rounded-circle speak-btn" type="button" id="dictSpeakBtn" title="Phát âm">
                        <i class="fas fa-volume-high"></i>
                    </button>
                </div>
                
                <div class="mb-4">
                    <div class="p-3 bg-primary-subtle rounded-3 shadow-sm border-start border-4 border-primary">
                        <span class="fs-5 fw-bold text-primary text-capitalize" id="dictMeaning"></span>
                    </div>
                </div>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="mb-4 bg-light p-3 rounded-3 shadow-sm border">
                        <label class="form-label fw-bold small text-muted"><i class="fas fa-plus-circle me-1"></i>Lưu vào bộ từ vựng</label>
                        <div class="input-group">
                            <select id="dictSaveSetSelect" class="form-select form-select-sm">
                                <option value="">Đang tải...</option>
                            </select>
                            <button id="dictSaveWordBtn" class="btn btn-sm btn-primary" type="button">Lưu từ</button>
                        </div>
                        <div id="dictSaveMsg" class="small mt-2 d-none"></div>
                    </div>
                }

                <div id="dictMeaningsContainer">
                    <!-- Dynamic content injected here -->
                </div>
            </div>
            
            <div id="dictError" class="d-none alert alert-danger rounded-3 shadow-sm">
                <i class="fas fa-exclamation-triangle me-2"></i><span id="dictErrorText">Không tìm thấy từ này.</span>
            </div>
            <hr class="my-4" />

            <section class="ai-chat-panel">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="fw-bold mb-0"><i class="fas fa-comments me-2 text-primary"></i>Hỏi AI và lưu lịch sử</h6>
                    <button class="btn btn-sm btn-outline-primary" type="button" id="aiNewChatBtn" title="Tạo mới">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>

                <div class="d-flex gap-2 mb-3">
                    <select class="form-select form-select-sm" id="aiConversationSelect" aria-label="Lịch sử hội thoại">
                        <option value="">Cuộc trò chuyện mới</option>
                    </select>
                    <button class="btn btn-sm btn-outline-danger" type="button" id="aiDeleteChatBtn" title="Xóa cuộc trò chuyện">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>

                <div id="aiChatError" class="alert alert-danger d-none rounded-3 shadow-sm small"></div>

                <div id="aiChatMessages" class="ai-chat-messages mb-3">
                    <div class="ai-empty-state text-center text-muted py-4">
                        <i class="fas fa-wand-magic-sparkles fs-2 mb-3 text-primary"></i>
                        <p class="mb-1 fw-semibold">Hỏi AI về từ vựng, ví dụ, ngữ pháp.</p>
                        <p class="small mb-0">Lịch sử sẽ được lưu riêng cho tài khoản của bạn.</p>
                    </div>
                </div>

                <form id="aiChatForm">
                    <div class="input-group shadow-sm rounded-3 overflow-hidden">
                        <textarea id="aiChatInput" class="form-control border-0" rows="2" placeholder="Ví dụ: Phân biệt affect và effect..." required></textarea>
                        <button class="btn btn-primary-gradient px-3" type="submit" id="aiChatSendBtn">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </form>
                <div id="aiChatLoading" class="small text-muted mt-2 d-none">
                    <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>Gemini đang trả lời...
                </div>
            </section>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js?v=@DateTime.Now.Ticks" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
