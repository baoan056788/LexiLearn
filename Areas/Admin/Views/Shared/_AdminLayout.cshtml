<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LexiLearn Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }
        .sidebar { min-height: 100vh; background-color: #343a40; color: #fff; }
        .sidebar .nav-link { color: #c2c7d0; font-weight: 500; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background-color: rgba(255,255,255,.1); border-radius: 5px;}
        .main-content { min-height: 100vh; }
        .top-navbar { background-color: #fff; box-shadow: 0 2px 4px rgba(0,0,0,.08); }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="sidebar p-3" style="width: 250px;">
            <a href="/Admin/Dashboard" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none">
                <i class="fas fa-book-open fs-4 me-2 text-primary"></i>
                <span class="fs-4 fw-bold">LexiAdmin</span>
            </a>
            <hr>
            <ul class="nav nav-pills flex-column mb-auto gap-1">
                <li class="nav-item">
                    <a href="/Admin/Dashboard" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <i class="fas fa-tachometer-alt fa-fw me-2"></i> Dashboard
                    </a>
                </li>
                <li>
                    <a href="/Admin/User" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")">
                        <i class="fas fa-users fa-fw me-2"></i> Người dùng
                    </a>
                </li>
                <li>
                    <a href="/Admin/VocabularySet" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "VocabularySet" ? "active" : "")">
                        <i class="fas fa-layer-group fa-fw me-2"></i> Bộ từ vựng
                    </a>
                </li>
                <li>
                    <a href="/Admin/Category" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                        <i class="fas fa-tags fa-fw me-2"></i> Danh mục
                    </a>
                </li>
                <li>
                    <a href="/Admin/Dictionary" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dictionary" ? "active" : "")">
                        <i class="fas fa-spell-check fa-fw me-2"></i> Từ điển
                    </a>
                </li>
                <li>
                    <a href="/Admin/Report" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" ? "active" : "")">
                        <i class="fas fa-flag fa-fw me-2"></i> Báo cáo vi phạm
                    </a>
                </li>
                <li>
                    <a href="/Admin/Notification" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notification" ? "active" : "")">
                        <i class="fas fa-bell fa-fw me-2"></i> Thông báo
                    </a>
                </li>
                <li>
                    <a href="/Admin/Feedback" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Feedback" ? "active" : "")">
                        <i class="fas fa-comment-dots fa-fw me-2"></i> Phản hồi
                    </a>
                </li>
                <li>
                    <a href="/Admin/Setting" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Setting" ? "active" : "")">
                        <i class="fas fa-cog fa-fw me-2"></i> Cài đặt
                    </a>
                </li>
            </ul>
        </div>

        <!-- Main Content -->
        <div class="flex-grow-1 main-content d-flex flex-column">
            <!-- Navbar -->
            <nav class="navbar top-navbar px-4 py-2 d-flex justify-content-between align-items-center">
                <h5 class="m-0 fw-bold">@ViewData["Title"]</h5>
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="https://ui-avatars.com/api/?name=Admin&background=random" alt="" width="32" height="32" class="rounded-circle me-2">
                        <strong>@User.Identity?.Name</strong>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="dropdownUser1">
                        <li><a class="dropdown-item" href="/"><i class="fas fa-home me-2"></i>Về trang chủ</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="/Auth/Logout"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                    </ul>
                </div>
            </nav>

            <!-- Page Content -->
            <div class="p-4 flex-grow-1">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @RenderBody()
            </div>
            
            <footer class="bg-white text-center py-3 border-top small text-muted">
                &copy; 2026 LexiLearn Admin Panel. All rights reserved.
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
