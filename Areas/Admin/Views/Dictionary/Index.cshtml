@model IEnumerable<LexiLearn.Models.WordDefinition>
@{
    ViewData["Title"] = "Từ điển Nội bộ";
}

<div class="card border-0 shadow-sm rounded-3">
    <div class="card-header bg-white pt-4 pb-3 border-bottom-0 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0">Dữ liệu Từ vựng Hệ thống</h5>
        <button class="btn btn-primary" onclick="alert('Tính năng nhập dữ liệu đang được phát triển!')"><i class="fas fa-file-import me-2"></i>Nhập dữ liệu (Excel/CSV)</button>
    </div>
    <div class="card-body">
        <form method="get" class="mb-4 d-flex">
            <input type="text" name="searchString" class="form-control me-2" placeholder="Tra cứu từ vựng..." value="@ViewBag.SearchString" style="max-width: 400px;">
            <button type="submit" class="btn btn-secondary"><i class="fas fa-search"></i></button>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Từ vựng</th>
                        <th>Từ loại</th>
                        <th>Phiên âm</th>
                        <th>Định nghĩa</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong class="text-primary fs-5">@item.Word</strong></td>
                            <td><span class="badge bg-light text-dark border">@string.Join(", ", item.WordTypes.Select(w => w.PartOfSpeech))</span></td>
                            <td class="font-monospace text-muted">@item.Phonetic</td>
                            <td style="max-width: 400px;" class="text-truncate">@(item.WordTypes.FirstOrDefault()?.Meaning ?? "N/A")</td>
                            <td class="text-end">
                                <form action="/Admin/Dictionary/Delete" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@item.WordId" />
                                    <button type="submit" class="btn btn-sm btn-light text-danger border" onclick="return confirm('Bạn có chắc chắn muốn xóa từ này khỏi hệ thống?');">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fas fa-book fs-1 mb-3 text-light"></i>
                                <p>Từ điển nội bộ hiện đang trống hoặc không tìm thấy từ này.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="/Admin/Dictionary?page=@i&searchString=@ViewBag.SearchString">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>
