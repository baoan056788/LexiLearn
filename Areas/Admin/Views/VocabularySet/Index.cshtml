@model IEnumerable<LexiLearn.Models.VocabularySet>
@{
    ViewData["Title"] = "Quản lý Bộ từ vựng";
}

<div class="card border-0 shadow-sm rounded-3 mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                <input type="text" name="searchString" class="form-control" placeholder="Tìm kiếm tên bộ từ..." value="@ViewBag.SearchString">
            </div>
            <div class="col-md-4">
                <select name="categoryId" class="form-select">
                    <option value="">-- Tất cả Danh mục --</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        if (ViewBag.CategoryId != null && cat.CategoryId == ViewBag.CategoryId)
                        {
                            <option value="@cat.CategoryId" selected>@cat.CategoryName</option>
                        }
                        else
                        {
                            <option value="@cat.CategoryId">@cat.CategoryName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-secondary w-100"><i class="fas fa-search me-2"></i>Lọc danh sách</button>
            </div>
        </form>
    </div>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4 col-xl-3">
            <div class="card h-100 border-0 shadow-sm rounded-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-light text-dark border">@item.Category?.CategoryName</span>
                        @if (item.IsPublic)
                        {
                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25" title="Công khai"><i class="fas fa-globe-americas"></i></span>
                        }
                        else
                        {
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25" title="Riêng tư"><i class="fas fa-lock"></i></span>
                        }
                    </div>
                    <h5 class="card-title fw-bold text-truncate" title="@item.Title">@item.Title</h5>
                    <p class="card-text text-muted small text-truncate-2" style="height: 40px;">@(item.Description ?? "Không có mô tả")</p>
                    
                    <div class="d-flex align-items-center mb-3">
                        <img src="@(item.User?.AvatarUrl ?? $"https://ui-avatars.com/api/?name={item.User?.FullName}&background=random")" class="rounded-circle me-2" width="24" height="24" alt="">
                        <small class="text-muted text-truncate">@item.User?.FullName</small>
                    </div>
                    
                </div>
                <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center">
                    <small class="text-muted"><i class="far fa-calendar-alt me-1"></i>@item.CreatedAt.ToString("dd/MM/yyyy")</small>
                    <div>
                        <a href="/Admin/VocabularySet/Details/@item.SetId" class="btn btn-sm btn-primary"><i class="fas fa-eye"></i> Chi tiết</a>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12 text-center py-5">
            <i class="fas fa-search fs-1 text-muted mb-3"></i>
            <p class="text-muted">Không tìm thấy bộ từ vựng nào.</p>
        </div>
    }
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="/Admin/VocabularySet?page=@i&searchString=@ViewBag.SearchString&categoryId=@ViewBag.CategoryId">@i</a>
                </li>
            }
        </ul>
    </nav>
}
